#!/usr/bin/env bash
# MultiManager .app launcher (uv venv)
DIR="$(cd "$(dirname "$0")/../../../.." && pwd)"
VENV="$DIR/MultiManager/.venv"
if [ -f "$VENV/bin/activate" ]; then
    source "$VENV/bin/activate"
else
    export PYTHONPATH="$DIR/MultiManager:$PYTHONPATH"
fi
cd "$DIR/MultiManager" && exec python3 app.py
